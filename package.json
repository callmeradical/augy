{
  "name": "@callmeradical/augy",
  "version": "0.2.0",
  "description": "Homebrew for AI agent skills — install, version, update, rollback",
  "type": "module",
  "license": "MIT",
  "author": "Lars Cromley",
  "homepage": "https://callmeradical.github.io/augy",
  "repository": {
    "type": "git",
    "url": "https://github.com/callmeradical/augy.git"
  },
  "bugs": {
    "url": "https://github.com/callmeradical/augy/issues"
  },
  "keywords": [
    "ai",
    "skills",
    "cli",
    "package-manager",
    "opencode",
    "claude",
    "codex",
    "agent"
  ],
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "augy": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --outDir dist --clean",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "diff": "^9.0.0",
    "giget": "^3.2.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
